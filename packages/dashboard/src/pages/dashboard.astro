---
// dashboard.astro — Jellyfish Agent Admin Dashboard
// Data is loaded client-side via /api/agent/detail
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Agent Dashboard · Jellyfish</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#09090b;--card-bg:rgba(24,24,27,0.6);--card-border:rgba(255,255,255,0.08);--primary:#c1939b;--primary-hover:#ad7982;--primary-glow:rgba(193,147,155,0.3);--text:#fafafa;--text-muted:#a1a1aa;--input-bg:rgba(9,9,11,0.5);--input-border:rgba(255,255,255,0.1);--error:#ef4444;--success:#10b981}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;position:relative;line-height:1.5}
    .blob{position:fixed;border-radius:50%;filter:blur(80px);z-index:-1;opacity:0.5;animation:float 20s infinite alternate}
    .blob-1{width:400px;height:400px;background:radial-gradient(circle,var(--primary) 0%,transparent 70%);top:-100px;left:-100px}
    .blob-2{width:600px;height:600px;background:radial-gradient(circle,#ebb5b2 0%,transparent 70%);bottom:-200px;right:-200px;animation-delay:-5s}
    @keyframes float{0%{transform:translateY(0) scale(1)}100%{transform:translateY(-50px) scale(1.1)}}
    .page-wrapper{max-width:960px;margin:0 auto;padding:40px 20px}
    header{text-align:center;margin-bottom:32px;position:relative}
    h1{font-size:2rem;font-weight:700;letter-spacing:-.02em}
    .text-gradient{background:linear-gradient(135deg,#dfa9b1,#ad7982);-webkit-background-clip:text;background-clip:text;color:transparent}
    .sub{color:var(--text-muted);font-size:.85rem;margin-top:4px}
    .header-actions{position:absolute;right:0;top:0;display:flex;gap:8px;align-items:center}
    #auth-gate{background:var(--card-bg);backdrop-filter:blur(12px);border:1px solid var(--card-border);border-radius:24px;padding:48px 32px;max-width:420px;margin:80px auto;text-align:center}
    #auth-gate h2{font-size:1.4rem;margin-bottom:8px}
    #auth-gate p{color:var(--text-muted);font-size:.9rem;margin-bottom:24px}
    .card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
    .card{background:var(--card-bg);backdrop-filter:blur(12px);border:1px solid var(--card-border);border-radius:16px;padding:20px;transition:border-color .2s}
    .card:hover{border-color:rgba(255,255,255,0.18)}
    .card h2{font-size:.9rem;font-weight:600;color:var(--primary);margin-bottom:6px}
    .card p{font-size:.82rem;color:var(--text-muted);margin-bottom:14px;line-height:1.55}
    .wide{grid-column:1/-1}
    .btn{display:inline-flex;align-items:center;justify-content:center;height:40px;padding:0 18px;border-radius:10px;font-weight:600;font-size:.85rem;cursor:pointer;transition:all .2s;border:none;font-family:inherit;white-space:nowrap;text-decoration:none}
    .btn-primary{background:var(--primary);color:#fff;box-shadow:0 4px 14px 0 var(--primary-glow)}
    .btn-primary:hover{background:var(--primary-hover);transform:translateY(-1px)}
    .btn-ghost{background:transparent;color:var(--text-muted);border:1px solid var(--input-border)}
    .btn-ghost:hover{background:rgba(255,255,255,0.05);color:var(--text)}
    .btn-danger{background:rgba(239,68,68,0.15);color:#fca5a5;border:1px solid rgba(239,68,68,0.25)}
    .btn+.btn{margin-left:8px}
    input[type=text],input[type=number],input[type=password],textarea{width:100%;background:var(--input-bg);border:1px solid var(--input-border);color:var(--text);padding:10px 14px;border-radius:10px;font-size:.88rem;font-family:inherit;transition:all .2s;margin-top:6px}
    input:focus,textarea:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-glow)}
    input[type=number]{-moz-appearance:textfield;appearance:textfield;padding-right:10px;border-right:3px solid rgba(193,147,155,0.35)}
    input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
    textarea{min-height:300px;resize:vertical;font-family:'JetBrains Mono',monospace;font-size:.8rem}
    label{display:block;font-weight:500;font-size:.85rem;color:#e4e4e7;margin-top:14px}
    .cfg-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px}
    #output{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:min(860px,96vw);max-height:52vh;background:rgba(5,5,10,.97);border:1px solid rgba(134,239,172,.2);border-bottom:none;border-radius:14px 14px 0 0;padding:0;font-family:'JetBrains Mono',monospace;font-size:.78rem;color:#86efac;line-height:1.6;z-index:9999;display:none;overflow:hidden;box-shadow:0 -8px 40px rgba(0,0,0,.6);transition:transform .3s cubic-bezier(.16,1,.3,1)}
    #output.visible{transform:translateX(-50%) translateY(0)}
    #output-header{display:flex;align-items:center;justify-content:space-between;padding:9px 16px;border-bottom:1px solid rgba(134,239,172,.1);background:rgba(134,239,172,.05);font-size:.72rem;color:rgba(134,239,172,.6)}
    #output-header button{background:none;border:none;color:rgba(134,239,172,.5);cursor:pointer;font-size:1rem;line-height:1}
    #output-body{padding:12px 16px;overflow-y:auto;max-height:calc(52vh - 36px);white-space:pre-wrap;word-break:break-all}
    .section-title{font-size:.75rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted);margin:28px 0 12px}
    .status-tag{display:inline-block;font-size:.78rem;padding:.15rem .5rem;border-radius:6px;margin-left:10px;transition:all .3s}
    .lang-en{display:none!important}.lang-zh{display:inline}
    body.en-mode .lang-zh{display:none!important}body.en-mode .lang-en{display:inline!important}
    .vip-chip{display:inline-flex;align-items:center;gap:5px;padding:.2rem .6rem .2rem .7rem;background:rgba(20,184,166,0.1);border:1px solid rgba(20,184,166,0.25);border-radius:999px;color:#5eead4;margin:.2rem .15rem;font-size:.78rem;font-family:monospace;letter-spacing:.01em;transition:border-color .15s,background .15s}
    .vip-chip:hover{background:rgba(20,184,166,0.15);border-color:rgba(20,184,166,0.4)}
    .vip-chip .chip-del{background:none;border:none;color:rgba(248,113,113,0.4);cursor:pointer;font-size:.9rem;line-height:1;padding:0;transition:color .15s}
    .vip-chip .chip-del:hover{color:#f87171}
    .btn-loading{position:relative;pointer-events:none;opacity:.75}
    .btn-loading::after{content:'';position:absolute;right:10px;top:50%;width:14px;height:14px;margin-top:-7px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    .skeleton{background:linear-gradient(90deg,rgba(255,255,255,.05) 25%,rgba(255,255,255,.1) 50%,rgba(255,255,255,.05) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:6px;height:1em;display:inline-block;min-width:80px}
    @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
  </style>
</head>
<body>
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>

<!-- Auth Gate -->
<div id="auth-gate">
  <h2>🔐 <span class="lang-zh">进入控制台</span><span class="lang-en">Enter Dashboard</span></h2>
  <div style="margin-top:16px">
    <button class="btn btn-primary" onclick="startOAuth()" style="width:100%;height:44px;background:#1da1f2;margin-bottom:12px">
      <span class="lang-zh">使用 X (Twitter) 登录</span><span class="lang-en">Log in with X (Twitter)</span>
    </button>
    <div style="text-align:center;font-size:0.8rem;color:#71717a;margin-bottom:12px">
      <span class="lang-zh">或使用密码登录</span><span class="lang-en">OR login with password</span>
    </div>
    <input type="password" id="secret-input" placeholder="Dashboard Secret" style="margin-bottom:14px">
    <button class="btn btn-ghost" onclick="doAuthSecret()" style="width:100%;height:44px">
      <span class="lang-zh">密码验证</span><span class="lang-en">Verify Password</span>
    </button>
  </div>
  <div id="auth-err" style="color:var(--error);font-size:.82rem;margin-top:10px;display:none">
    <span class="lang-zh">验证失败</span><span class="lang-en">Verification failed</span>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard" style="display:none">
<div class="page-wrapper">
  <header>
    <div class="header-actions">
      <button id="langToggle" class="btn btn-ghost" style="padding:6px 12px;font-size:.8rem;height:auto">🌐 English</button>
      <button class="btn btn-ghost" onclick="doLogout()" style="padding:6px 12px;font-size:.8rem;height:auto">
        <span class="lang-zh">退出</span><span class="lang-en">Logout</span>
      </button>
    </div>
    <h1 id="dash-name"><span class="skeleton" style="width:200px">&nbsp;</span> <span class="text-gradient">Dashboard</span></h1>
    <p class="sub" id="dash-sub"><span class="skeleton" style="width:160px">&nbsp;</span></p>
  </header>

  <!-- Token health warning banner (shown if refresh token has expired) -->
  <div id="token-warning" style="display:none;margin-bottom:20px;padding:16px 20px;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.4);border-radius:16px;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
    <div>
      <strong style="color:#f87171">⚠️ <span class="lang-zh">Twitter 授权已失效</span><span class="lang-en">Twitter Authorization Expired</span></strong>
      <p style="margin:4px 0 0;color:#a1a1aa;font-size:.85rem"><span class="lang-zh">Agent 的 Refresh Token 已无效，无法正常执行任务。请立即重新授权。</span><span class="lang-en">Agent's Refresh Token is invalid. Tasks will fail until you re-authorize.</span></p>
    </div>
    <button class="btn btn-danger" onclick="doReauth()" style="flex-shrink:0">🔗 <span class="lang-zh">立即重新授权</span><span class="lang-en">Re-authorize Now</span></button>
  </div>

  <!-- Manual Actions -->
  <div class="section-title"><span class="lang-zh">手动触发操作</span><span class="lang-en">Manual Actions</span></div>
  <div class="card-grid">
    <div class="card">
      <h2>📬 <span class="lang-zh">扫描提及</span><span class="lang-en">Scan Mentions</span></h2>
      <p><span class="lang-zh">立即扫描最新 @提及并回复</span><span class="lang-en">Scan latest @mentions and reply now</span></p>
      <p style="font-size:.8rem;color:var(--text-muted);margin-top:4px">🕒 <span class="lang-zh">自动扫描：每分钟触发，单次内<b>每 15 秒</b>扫描一轮，共 4 轮</span><span class="lang-en">Auto-scans: triggered every minute, 4 sweeps at <b>15s</b> intervals</span></p>
      <a class="btn btn-primary" href="#" onclick="run(event,getApiUrl('/api/agent/trigger'));return false"><span class="lang-zh">立即触发</span><span class="lang-en">Trigger Now</span></a>
    </div>
    <div class="card">
      <h2>👀 <span class="lang-zh">刷时间线</span><span class="lang-en">Browse Timeline</span></h2>
      <p><span class="lang-zh">扫描粉丝/特别用户列表，随机点赞或回复 2 条推文</span><span class="lang-en">Scan fans/special users, randomly like or reply to 2 tweets</span></p>
      <p style="font-size:.8rem;color:var(--text-muted);margin-top:4px">🕒 <span class="lang-zh">自动执行：<b>每小时整点</b>一次</span><span class="lang-en">Auto-runs: once per hour on the hour</span></p>
      <p style="font-size:.75rem;color:#a78bfa;margin-top:6px">⭐ <span class="lang-zh">手动触发为 Pro 功能</span><span class="lang-en">Manual trigger is a Pro feature</span></p>
    </div>
    <div class="card">
      <h2>💬 <span class="lang-zh">自发推文</span><span class="lang-en">Spontaneous Tweet</span></h2>
      <p><span class="lang-zh">随机生成并发布一条自发推文</span><span class="lang-en">Generate and post a spontaneous tweet</span></p>
      <p style="font-size:.8rem;color:var(--text-muted);margin-top:4px">🕒 <span class="lang-zh">自动触发：每日 <b>UTC 12:30</b>，冷却固定 <b>3 天</b></span><span class="lang-en">Auto-triggers daily at <b>UTC 12:30</b>; <b>3-day</b> cooldown</span></p>
      <p style="font-size:.75rem;color:#a78bfa;margin-top:6px">⭐ <span class="lang-zh">无视冷却发推为 Pro 功能</span><span class="lang-en">Bypassing cooldown is a Pro feature</span></p>
    </div>
    <div class="card">
      <h2>🧠 <span class="lang-zh">互动记忆</span><span class="lang-en">Interaction Memory</span></h2>
      <p><span class="lang-zh">查看白名单用户塑造 Agent 的历史互动记录</span><span class="lang-en">View historical interaction records shaping the Agent</span></p>
      <p style="font-size:.8rem;color:var(--text-muted);margin-top:4px">🕒 <span class="lang-zh">自动刷取：每 <b>6 小时</b>一次</span><span class="lang-en">Auto-refreshes every <b>6 hours</b></span></p>
      <a class="btn btn-ghost" id="view-memory-btn" href="#" target="_blank"><span class="lang-zh">查看记忆</span><span class="lang-en">View Memory</span></a>
      <p style="font-size:.75rem;color:#a78bfa;margin-top:8px">⭐ <span class="lang-zh">立即强制拉取为 Pro 功能</span><span class="lang-en">Instant force-refresh is a Pro feature</span></p>
    </div>
    <div class="card">
      <h2 style="color:#c084fc">🧬 <span class="lang-zh">人格演化</span><span class="lang-en">Persona Evolution</span></h2>
      <p><span class="lang-zh">吸收现有记忆重塑底层人格（执行后清空记忆库）</span><span class="lang-en">Absorb memories to reshape persona (clears memory after)</span></p>
      <p style="font-size:.8rem;color:var(--text-muted);margin-top:4px">🕒 <span class="lang-zh">自动执行：每日 <b>UTC 03:00</b>，需开启「自动演化」</span><span class="lang-en">Auto-runs: daily at <b>UTC 03:00</b>, requires "Auto Evolution" enabled</span></p>
      <p style="font-size:.75rem;color:#a78bfa;margin-top:6px">⭐ <span class="lang-zh">立即强制重塑为 Pro 功能</span><span class="lang-en">Instant force-evolve is a Pro feature</span></p>
    </div>
    <div class="card">
      <h2>📊 <span class="lang-zh">Agent 状态</span><span class="lang-en">Agent Status</span></h2>
      <p><span class="lang-zh">查看当前状态与配置信息</span><span class="lang-en">View current status and configuration</span></p>
      <a class="btn btn-ghost" href="#" onclick="run(event,getApiUrl('/api/agent/status'));return false"><span class="lang-zh">查看</span><span class="lang-en">View</span></a>
      <a class="btn btn-ghost" id="activity-log-btn" href="#" target="_blank"><span class="lang-zh">活动日志</span><span class="lang-en">Activity Log</span></a>
    </div>
  </div>

  <!-- Pro Features -->
  <div class="section-title" style="background:linear-gradient(90deg,#7c3aed22,transparent);border-left:3px solid #7c3aed;padding-left:12px">
    ⭐ <span class="lang-zh">Pro 功能</span><span class="lang-en">Pro Features</span>
  </div>
  <div class="card wide" style="border-color:rgba(139,92,246,0.35);margin-bottom:20px;padding-bottom:20px">
    <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;margin-bottom:16px">
      <div style="flex:1;min-width:220px">
        <h2 style="color:#a78bfa;margin-bottom:6px">🔑 <span class="lang-zh">授权码</span><span class="lang-en">License Key</span></h2>
        <p style="font-size:.82rem;color:var(--text-muted);margin-bottom:10px">
          <span class="lang-zh">输入有效的授权码以解锁 Pro 功能（支持按月订阅）。购买后会将授权码发送到你的邮箱。</span>
          <span class="lang-en">Enter a valid license key to unlock Pro features (monthly subscription). The key will be emailed after purchase.</span>
        </p>
        <div style="display:flex;gap:8px;align-items:center">
          <input id="pro-key-input" type="text" placeholder="JLYF-XXXX-XXXX-XXXX" style="margin:0;flex:1;font-family:monospace;letter-spacing:.05em"/>
          <button class="btn btn-ghost" style="border-color:rgba(139,92,246,0.5);color:#a78bfa;white-space:nowrap" onclick="activateProKey()">
            <span class="lang-zh">激活</span><span class="lang-en">Activate</span>
          </button>
        </div>
        <div id="pro-key-status" style="font-size:.78rem;margin-top:6px">
          <span style="color:var(--text-muted)">🔒 <span class="lang-zh">加载中…</span><span class="lang-en">Loading…</span></span>
        </div>
        <div style="margin-top:14px">
          <script type='text/javascript' src='https://storage.ko-fi.com/cdn/widget/Widget_2.js'></script>
          <script type='text/javascript'>kofiwidget2.init('Support me on Ko-fi', '#6d28d9', 'K3K51XDNXI');kofiwidget2.draw();</script>
        </div>
      </div>
    </div>
    <hr style="border:none;border-top:1px solid rgba(139,92,246,0.12);margin:0 0 14px">
    <p style="font-size:.78rem;color:var(--text-muted);margin-bottom:12px">
      <span class="lang-zh">以下功能需要有效授权码才可使用</span>
      <span class="lang-en">The following actions require an active Pro license</span>
    </p>
    <div class="card-grid" style="gap:10px">
      <div class="card" style="border-color:rgba(139,92,246,0.25)">
        <h2 style="font-size:.95rem">👀 <span class="lang-zh">刷时间线</span><span class="lang-en">Browse Timeline</span></h2>
        <p style="font-size:.78rem"><span class="lang-zh">立即扫描特别用户列表，随机点赞或回复</span><span class="lang-en">Scan special users, randomly like or reply now</span></p>
        <a class="btn btn-ghost" style="border-color:rgba(139,92,246,0.4);color:#a78bfa" href="#" onclick="runPro(event,getApiUrl('/api/agent/trigger-timeline'));return false"><span class="lang-zh">立即执行</span><span class="lang-en">Run Now</span></a>
      </div>
      <div class="card" style="border-color:rgba(139,92,246,0.25)">
        <h2 style="font-size:.95rem">💬 <span class="lang-zh">无视冷却发推</span><span class="lang-en">Force Tweet</span></h2>
        <p style="font-size:.78rem"><span class="lang-zh">跳过 3 天冷却限制，立即发布一条自发推文</span><span class="lang-en">Skip the 3-day cooldown and post a tweet now</span></p>
        <a class="btn btn-ghost" style="border-color:rgba(139,92,246,0.4);color:#a78bfa" href="#" onclick="runPro(event,getApiUrl('/api/agent/spontaneous')+'&force=true');return false"><span class="lang-zh">立即发布</span><span class="lang-en">Post Now</span></a>
      </div>
      <div class="card" style="border-color:rgba(139,92,246,0.25)">
        <h2 style="font-size:.95rem">🧠 <span class="lang-zh">立即拉取记忆</span><span class="lang-en">Force Refresh Memory</span></h2>
        <p style="font-size:.78rem"><span class="lang-zh">跳过每 6 小时周期，立即拉取最新互动记忆</span><span class="lang-en">Skip the 6h schedule and refresh memories now</span></p>
        <a class="btn btn-ghost" style="border-color:rgba(139,92,246,0.4);color:#a78bfa" href="#" onclick="runPro(event,getApiUrl('/api/agent/refresh-memory'));return false"><span class="lang-zh">立即拉取</span><span class="lang-en">Refresh Now</span></a>
      </div>
      <div class="card" style="border-color:rgba(139,92,246,0.25)">
        <h2 style="font-size:.95rem">🧬 <span class="lang-zh">立即强制重塑</span><span class="lang-en">Force Evolve</span></h2>
        <p style="font-size:.78rem"><span class="lang-zh">跳过每日 UTC 03:00 周期，立即吸收记忆重塑人格</span><span class="lang-en">Skip the daily UTC 03:00 schedule and evolve persona now</span></p>
        <a class="btn btn-ghost" style="border-color:rgba(139,92,246,0.4);color:#a78bfa" href="#" onclick="runPro(event,getApiUrl('/api/agent/evolve'));return false"><span class="lang-zh">立即重塑</span><span class="lang-en">Evolve Now</span></a>
      </div>
    </div>
  </div>



  <!-- System Prompt -->
  <div class="section-title">✍️ <span class="lang-zh">微调人格</span><span class="lang-en">Fine-tune Persona</span></div>
  <div class="card wide" style="border-color:rgba(192,132,252,0.35)">
    <h2 style="color:#c084fc"><span class="lang-zh">System Prompt</span><span class="lang-en">System Prompt</span></h2>
    <p><span class="lang-zh">直接编辑人格配置文本，保存后下一次触发即生效</span><span class="lang-en">Edit persona text directly; takes effect on next trigger</span></p>
    <textarea id="skill-text"></textarea>
    <button class="btn btn-primary" onclick="saveSkill()">💾 <span class="lang-zh">保存人格</span><span class="lang-en">Save Persona</span></button>
    <span id="skill-status" class="status-tag"></span>
  </div>

  <!-- Configuration -->
  <div class="section-title"><span class="lang-zh">配置调节</span><span class="lang-en">Configuration</span></div>
  <div class="card-grid">
    <div class="card wide" style="border-color:rgba(37,99,235,0.4)">
      <h2 style="color:#60a5fa">⚙️ <span class="lang-zh">概率调节</span><span class="lang-en">Probability Settings</span></h2>
      <p><span class="lang-zh">调整回复概率与点赞概率</span><span class="lang-en">Adjust reply and like probability</span></p>
      <div class="cfg-grid" style="grid-template-columns:1fr 1fr">
        <label><span class="lang-zh">回复概率 (0~1)</span><span class="lang-en">Reply Probability (0~1)</span><input id="cfg-reply" type="number" step="0.05" min="0" max="1" value="0.2"></label>
        <label><span class="lang-zh">点赞概率 (0~1)</span><span class="lang-en">Like Probability (0~1)</span><input id="cfg-like" type="number" step="0.05" min="0" max="1" value="0.8"></label>
      </div>
      <button class="btn btn-primary" onclick="saveConfig()">💾 <span class="lang-zh">保存配置</span><span class="lang-en">Save Settings</span></button>
      <span id="config-status" class="status-tag"></span>
    </div>

    <!-- Special User Rules -->
    <div class="card wide" style="border-color:rgba(251,191,36,0.4)">
      <h2 style="color:#fbbf24">❤️ <span class="lang-zh">特别用户规则</span><span class="lang-en">Special User Rules</span></h2>
      <p><span class="lang-zh">为指定用户设置单独的回复/点赞概率和备注 persona。这些用户会被优先置入时间线队列。</span><span class="lang-en">Set per-user reply/like probabilities and persona note. These users are prioritized in timeline engagement.</span></p>
      <table id="vip-table" style="width:100%;border-collapse:collapse;font-size:.82rem;margin:12px 0">
        <thead><tr style="color:var(--text-muted);border-bottom:1px solid var(--card-border)">
          <th style="text-align:left;padding:6px 4px"><span class="lang-zh">Handle</span></th>
          <th style="text-align:left;padding:6px 4px"><span class="lang-zh">回复</span><span class="lang-en">Reply</span></th>
          <th style="text-align:left;padding:6px 4px"><span class="lang-zh">点赞</span><span class="lang-en">Like</span></th>
          <th style="text-align:left;padding:6px 4px"><span class="lang-zh">备注</span><span class="lang-en">Persona</span></th>
          <th></th>
        </tr></thead>
        <tbody id="vip-tbody"></tbody>
      </table>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr 2fr auto;gap:8px;align-items:end;margin-top:8px">
        <label><span class="lang-zh">Handle</span><input id="vip-new-handle" type="text" placeholder="handle" style="margin-top:4px"></label>
        <label><span class="lang-zh">回复</span><span class="lang-en">Reply</span><input id="vip-new-reply" type="number" min="0" max="1" step="0.05" value="0.8" style="margin-top:4px"></label>
        <label><span class="lang-zh">点赞</span><span class="lang-en">Like</span><input id="vip-new-like" type="number" min="0" max="1" step="0.05" value="1" style="margin-top:4px"></label>
        <label><span class="lang-zh">Persona 备注</span><span class="lang-en">Persona note</span><input id="vip-new-persona" type="text" placeholder="e.g. 主人" style="margin-top:4px"></label>
        <button class="btn btn-primary" style="margin-top:0;height:44px" onclick="addVip()">✚ <span class="lang-zh">添加</span><span class="lang-en">Add</span></button>
      </div>
      <span id="vip-status" class="status-tag"></span>
    </div>

    <!-- Memory Whitelist -->
    <div class="card wide" style="border-color:rgba(16,185,129,0.4)">
      <h2>🔒 <span class="lang-zh">互动记忆白名单</span><span class="lang-en">Memory Whitelist</span></h2>
      <p><span class="lang-zh">只有白名单用户的互动会被纳入记忆库。填 <code>all</code> 表示接受所有人。</span><span class="lang-en">Only interactions from whitelisted users are stored. Use <code>all</code> to accept everyone.</span></p>
      <div style="margin:10px 0 6px">
        <label><input type="radio" name="wl-mode" value="all"> <span class="lang-zh">接受所有人 (all)</span><span class="lang-en">Accept all (all)</span></label>
        <label style="margin-top:8px"><input type="radio" name="wl-mode" value="list"> <span class="lang-zh">指定白名单</span><span class="lang-en">Specific list</span></label>
      </div>
      <div id="wl-list-area" style="display:none">
        <div id="wl-chips" style="display:flex;flex-wrap:wrap;gap:0;margin:10px 0;min-height:28px;align-items:center"></div>
        <div style="display:flex;gap:8px">
          <input id="wl-new-handle" type="text" placeholder="@handle" style="margin:0">
          <button class="btn btn-ghost" onclick="addWlHandle()">✚</button>
        </div>
      </div>
      <button class="btn btn-primary" style="margin-top:12px" onclick="saveWhitelist()">💾 <span class="lang-zh">保存</span><span class="lang-en">Save</span></button>
      <span id="wl-status" class="status-tag"></span>
    </div>

    <!-- Dashboard Secret -->
    <div class="card wide" style="border-color:rgba(239,68,68,0.4)">
      <h2 style="color:#f87171">🔑 <span class="lang-zh">控制台密码</span><span class="lang-en">Dashboard Secret</span></h2>
      <p><span class="lang-zh">设置或更新控制台访问密码</span><span class="lang-en">Set or update dashboard access password</span></p>
      <div style="display:flex;gap:12px;margin-bottom:14px">
        <input id="dash-secret-update" type="password" placeholder="New Secret" style="max-width:300px;margin-top:0">
        <button class="btn btn-danger" onclick="updateDashSecret()">💾 <span class="lang-zh">保存密码</span><span class="lang-en">Save Password</span></button>
      </div>
      <span id="secret-status" class="status-tag"></span>
    </div>

    <!-- Re-authorize -->
    <div class="card wide" style="border-color:rgba(234,179,8,0.4)">
      <h2 style="color:#fbbf24">🔄 <span class="lang-zh">重新授权 X 账号</span><span class="lang-en">Re-authorize X Account</span></h2>
      <p><span class="lang-zh">当 Refresh Token 失效或被撤销时，重新走一遍 OAuth 授权流程以恢复 Agent 正常运行。</span><span class="lang-en">Re-run the OAuth flow to recover the Agent when its Refresh Token has expired or been revoked.</span></p>
      <button class="btn btn-ghost" id="reauthBtn" onclick="doReauth()" style="border-color:rgba(234,179,8,0.4);color:#fbbf24">
        🔗 <span class="lang-zh">开始重新授权</span><span class="lang-en">Start Re-authorization</span>
      </button>
      <div id="reauth-status" class="status-tag" style="margin-left:12px"></div>
    </div>
  </div>
</div>
</div>

<!-- Output Panel -->
<div id="output">
  <div id="output-header">
    <span>🖥️ <span class="lang-zh">操作结果</span><span class="lang-en">Output</span></span>
    <button id="output-close" onclick="closeOutput()">✕</button>
  </div>
  <div id="output-body"></div>
</div>

<script is:inline>
  // ── State ────────────────────────────────────────────────────────────────
  var _agentId = new URLSearchParams(location.search).get('id') || '';
  var _agentData = null;
  var _vipList = [];
  var _wlHandles = [];
  var _sessionToken = sessionStorage.getItem('sessionToken') || '';

  function getApiUrl(path) {
    return path + '?id=' + _agentId;
  }

  function authHeaders() {
    var h = { 'Content-Type': 'application/json' };
    if (_sessionToken) h['X-Session-Token'] = _sessionToken;
    return h;
  }

  // ── Auth ─────────────────────────────────────────────────────────────────
  (function init() {
    var saved = sessionStorage.getItem('dashSecret');
    _sessionToken = sessionStorage.getItem('sessionToken') || '';
    if (_sessionToken) { showDashboard(); return; }
    if (saved) doAuthSecret(saved);
  })();

  window.addEventListener('message', async (e) => {
    if (e.data && e.data.type === 'oauth_success') verifyOAuth(e.data.accessToken);
  });

  async function startOAuth() {
    var popup = window.open('about:blank', 'oauth', 'width=600,height=700');
    try {
      var r = await fetch('/api/oauth/start', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ currentOrigin: window.location.origin })
      });
      var d = await r.json();
      if (d.authUrl) { popup.location.href = d.authUrl; }
      else { popup.close(); alert('OAuth error: ' + (d.error || 'Unknown')); }
    } catch(e) { popup.close(); alert('OAuth error: ' + e.message); }
  }

  async function verifyOAuth(accessToken) {
    document.getElementById('auth-err').style.display = 'none';
    var r = await fetch('/api/agent/verify-owner', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ agentId: _agentId, accessToken })
    });
    var d = await r.json();
    if (d.ok) {
      _sessionToken = d.sessionToken || '';
      sessionStorage.setItem('sessionToken', _sessionToken);
      showDashboard();
    } else {
      var err = document.getElementById('auth-err');
      err.style.display = 'block';
      err.textContent = 'Auth failed: ' + (d.error || 'Handle mismatch');
    }
  }

  function doAuthSecret(prefill) {
    document.getElementById('auth-err').style.display = 'none';
    var s = prefill || document.getElementById('secret-input').value.trim();
    if (!s) return;
    verifySecretCall(s, !prefill);
  }

  async function verifySecretCall(secret, fromInput) {
    var r = await fetch('/api/agent/verify-secret', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ agentId: _agentId, secret })
    });
    var d = await r.json();
    if (d.ok) {
      sessionStorage.setItem('dashSecret', secret);
      _sessionToken = d.sessionToken || '';
      sessionStorage.setItem('sessionToken', _sessionToken);
      showDashboard();
    } else if (fromInput) {
      var err = document.getElementById('auth-err');
      err.style.display = 'block';
      err.textContent = document.body.classList.contains('en-mode') ? 'Incorrect password' : '密码错误';
    }
  }

  document.getElementById('secret-input')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') doAuthSecret();
  });

  function doLogout() {
    // Invalidate session on backend before clearing local state
    if (_sessionToken) {
      fetch('/api/agent/logout?id=' + _agentId, { method: 'POST', headers: { 'X-Session-Token': _sessionToken } }).catch(function(){});
    }
    sessionStorage.removeItem('dashSecret');
    sessionStorage.removeItem('sessionToken');
    location.reload();
  }

  function showDashboard() {
    document.getElementById('auth-gate').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
    loadAgentData();
    checkTokenHealth();
  }

  async function checkTokenHealth() {
    try {
      var r = await fetch(getApiUrl('/api/agent/token-health'));
      var d = await r.json();
      var banner = document.getElementById('token-warning');
      if (!d.healthy) {
        banner.style.display = 'flex';
        // Also highlight the reauth card
        var reauthCard = document.getElementById('reauthBtn');
        if (reauthCard) reauthCard.style.animation = 'pulse 2s infinite';
      } else {
        banner.style.display = 'none';
      }
    } catch(e) { /* silent — don't block dashboard */ }
  }

  // ── Load agent data ───────────────────────────────────────────────────────
  async function loadAgentData() {
    try {
      var r = await fetch(getApiUrl('/api/agent/detail'));
      _agentData = await r.json();
      if (!_agentData || _agentData.error) { console.error('Agent load failed', _agentData); return; }

      // Fill header
      document.getElementById('dash-name').innerHTML = _agentData.agent_name + ' <span class="text-gradient">Dashboard</span>';
      document.getElementById('dash-sub').innerHTML = '<span class="lang-zh">Agent ID:</span><span class="lang-en">Agent ID:</span> <code style="font-size:.78rem;opacity:.7">' + _agentId + '</code>';

      // Fill skill text
      document.getElementById('skill-text').value = _agentData.skill_text || '';

      // Fill config
      document.getElementById('cfg-reply').value = _agentData.reply_pct ?? 0.2;
      document.getElementById('cfg-like').value = _agentData.like_pct ?? 0.8;

      // Fill pro status
      var proExp = _agentData.pro_expires_at || 0;
      var proSt = document.getElementById('pro-key-status');
      if (proExp > Date.now()) {
        sessionStorage.setItem('pro_expires_at', String(proExp));
        proSt.innerHTML = '<span style="color:#86efac">✅ Pro 已激活，有效至 <b>' + (function(ts) { var d = new Date(ts); return (!ts || ts <= 0 || isNaN(d.getTime()) || ts > 3e12) ? '<span class="lang-zh">永远</span><span class="lang-en">Forever</span>' : d.toLocaleDateString('zh-CN'); })(proExp) + '</b></span>';
      } else {
        sessionStorage.removeItem('pro_expires_at');
        proSt.innerHTML = '<span style="color:var(--text-muted)">🔒 <span class="lang-zh">未激活</span><span class="lang-en">Not activated</span></span>';
      }

      // Fill VIP list
      _vipList = Array.isArray(_agentData.vip_list) ? _agentData.vip_list : [];
      renderVipTable();

      // Fill whitelist
      var wl = _agentData.mem_whitelist;
      if (wl === 'all') {
        document.querySelector('input[name="wl-mode"][value="all"]').checked = true;
        document.getElementById('wl-list-area').style.display = 'none';
      } else {
        document.querySelector('input[name="wl-mode"][value="list"]').checked = true;
        document.getElementById('wl-list-area').style.display = 'block';
        _wlHandles = Array.isArray(wl) ? wl : (typeof wl === 'string' ? JSON.parse(wl || '[]') : []);
        renderWlChips();
      }

      // Update href links
      document.getElementById('view-memory-btn').href = '/api/agent/memory?id=' + _agentId;
      document.getElementById('activity-log-btn').href = '/api/agent/activity?id=' + _agentId;
    } catch(e) { console.error('loadAgentData error:', e); }
  }

  async function fetchTwitterIdentity() {
    try {
      var r = await fetch(getApiUrl('/api/agent/twitter-identity'));
      var d = await r.json();
      if (d.name) document.getElementById('dash-name').innerHTML = d.name + ' <span class="text-gradient">Dashboard</span>';
    } catch(e) { console.warn('identity fetch failed:', e); }
  }

  // ── Language toggle ───────────────────────────────────────────────────────
  (function() {
    var btn = document.getElementById('langToggle');
    var setLang = function(lang) {
      if (lang === 'en') { document.body.classList.add('en-mode'); btn.textContent = '🌐 中文'; localStorage.setItem('agentSettingsLang', 'en'); }
      else { document.body.classList.remove('en-mode'); btn.textContent = '🌐 English'; localStorage.setItem('agentSettingsLang', 'zh'); }
    };
    if (localStorage.getItem('agentSettingsLang') === 'en') setLang('en');
    btn.addEventListener('click', function() { setLang(document.body.classList.contains('en-mode') ? 'zh' : 'en'); });
  })();

  // ── Output panel ──────────────────────────────────────────────────────────
  function closeOutput() {
    var out = document.getElementById('output');
    out.classList.remove('visible');
    setTimeout(function() { out.style.display = 'none'; }, 320);
  }

  async function run(event, path) {
    var btn = event && event.currentTarget;
    if (btn) { btn.classList.add('btn-loading'); }
    var out = document.getElementById('output'), body = document.getElementById('output-body');
    var isEn = document.body.classList.contains('en-mode');
    out.style.display = 'block';
    requestAnimationFrame(function() { requestAnimationFrame(function() { out.classList.add('visible'); }); });
    body.textContent = isEn ? '⏳ Requesting...' : '⏳ 请求中……';
    try {
      var res = await fetch(path, { headers: _sessionToken ? { 'X-Session-Token': _sessionToken } : {} });
      var text = await res.text();
      try { body.textContent = JSON.stringify(JSON.parse(text), null, 2); } catch(e) { body.textContent = text; }
    } catch(e) { body.textContent = '❌ ' + e.message; }
    if (btn) { btn.classList.remove('btn-loading'); btn.style.paddingRight = ''; }
  }

  async function runPro(event, path) {
    var proExp = parseInt(sessionStorage.getItem('pro_expires_at') || '0');
    if (!proExp || proExp < Date.now()) {
      alert(document.body.classList.contains('en-mode')
        ? '⭐ Pro license required. Please activate your license key above.'
        : '⭐ 需要 Pro 授权码，请先在上方激活。');
      return;
    }
    return run(event, path);
  }

  // ── Pro key activation ────────────────────────────────────────────────────
  async function activateProKey() {
    var key = document.getElementById('pro-key-input').value.trim().toUpperCase();
    var st = document.getElementById('pro-key-status');
    var isEn = document.body.classList.contains('en-mode');
    if (!key) { st.textContent = '⚠️ ' + (isEn ? 'Enter a key' : '请输入授权码'); st.style.color = '#fbbf24'; return; }
    st.textContent = isEn ? '⏳ Activating...' : '⏳ 激活中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch('/api/agent/activate-license', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ agentId: _agentId, key })
      });
      var d = await r.json();
      if (d.ok) {
        sessionStorage.setItem('pro_expires_at', String(d.expires_at));
        st.innerHTML = '<span style="color:#86efac">✅ Pro 已激活，有效至 <b>' + (function(ts) { var d = new Date(ts); return (!ts || ts <= 0 || isNaN(d.getTime()) || ts > 3e12) ? '<span class="lang-zh">永远</span><span class="lang-en">Forever</span>' : d.toLocaleDateString('zh-CN'); })(d.expires_at) + '</b></span>';
      } else {
        st.textContent = '❌ ' + d.error; st.style.color = '#f87171';
      }
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  // ── Save skill ────────────────────────────────────────────────────────────
  async function saveSkill() {
    var skill = document.getElementById('skill-text').value.trim();
    var st = document.getElementById('skill-status');
    var isEn = document.body.classList.contains('en-mode');
    if (!skill) { st.textContent = isEn ? '⚠️ Cannot be empty' : '⚠️ 不能为空'; st.style.color = '#fbbf24'; return; }
    st.textContent = isEn ? '⏳ Saving...' : '⏳ 保存中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/update-skill'), {
        method: 'POST', headers: authHeaders(), body: JSON.stringify({ skill })
      });
      var d = await r.json();
      st.textContent = d.ok ? (isEn ? '✅ Saved' : '✅ 已保存') : '❌ ' + d.error;
      st.style.color = d.ok ? '#86efac' : '#f87171';
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  // ── Save config ───────────────────────────────────────────────────────────
  async function saveConfig() {
    var st = document.getElementById('config-status');
    var isEn = document.body.classList.contains('en-mode');
    st.textContent = isEn ? '⏳ Saving...' : '⏳ 保存中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/update-config'), {
        method: 'POST', headers: authHeaders(),
        body: JSON.stringify({
          reply_pct: parseFloat(document.getElementById('cfg-reply').value),
          like_pct: parseFloat(document.getElementById('cfg-like').value),
          cooldown_days: 3
        })
      });
      var d = await r.json();
      st.textContent = d.ok ? (isEn ? '✅ Saved' : '✅ 已保存') : '❌ ' + d.error;
      st.style.color = d.ok ? '#86efac' : '#f87171';
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  // ── VIP table ─────────────────────────────────────────────────────────────
  function renderVipTable() {
    var tbody = document.getElementById('vip-tbody');
    tbody.innerHTML = '';
    _vipList.forEach(function(v, i) {
      var tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
      tr.innerHTML = '<td style="padding:6px 4px">@' + v.username + '</td>'
        + '<td style="padding:6px 4px">' + (v.replyProbability ?? '-') + '</td>'
        + '<td style="padding:6px 4px">' + (v.likeProbability ?? '-') + '</td>'
        + '<td style="padding:6px 4px;color:var(--text-muted)">' + (v.persona || '') + '</td>'
        + '<td style="padding:6px 4px"><button data-idx="' + i + '" class="vip-del-btn" style="background:none;border:none;cursor:pointer;color:rgba(248,113,113,0.45);font-size:1rem;line-height:1;padding:4px 8px;border-radius:8px;transition:color .15s,background .15s" onmouseover="this.style.color=\'#f87171\';this.style.background=\'rgba(239,68,68,0.1)\'" onmouseout="this.style.color=\'rgba(248,113,113,0.45)\';this.style.background=\'none\'">✕</button></td>';
      tbody.appendChild(tr);
    });
    tbody.querySelectorAll('.vip-del-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { deleteVip(parseInt(btn.getAttribute('data-idx'))); });
    });
  }

  async function _saveVip() {
    var st = document.getElementById('vip-status');
    st.textContent = '⏳'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/update-vip'), {
        method: 'POST', headers: authHeaders(), body: JSON.stringify({ vip_list: _vipList })
      });
      var d = await r.json();
      st.textContent = d.ok ? '✅' : '❌ ' + d.error;
      st.style.color = d.ok ? '#86efac' : '#f87171';
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  async function addVip() {
    var handle = document.getElementById('vip-new-handle').value.trim().replace(/^@/, '');
    var reply = parseFloat(document.getElementById('vip-new-reply').value);
    var like = parseFloat(document.getElementById('vip-new-like').value);
    var persona = document.getElementById('vip-new-persona').value.trim();
    var st = document.getElementById('vip-status');
    if (!handle) { st.textContent = '⚠️ Handle required'; st.style.color = '#fbbf24'; return; }
    if (_vipList.some(function(v){ return v.username.toLowerCase() === handle.toLowerCase(); })) {
      st.textContent = '⚠️ Already exists'; st.style.color = '#fbbf24'; return;
    }
    _vipList.push({ username: handle, replyProbability: reply, likeProbability: like, persona: persona || undefined });
    renderVipTable();
    document.getElementById('vip-new-handle').value = '';
    document.getElementById('vip-new-persona').value = '';
    await _saveVip();
  }

  async function deleteVip(idx) {
    _vipList.splice(idx, 1);
    renderVipTable();
    await _saveVip();
  }

  // ── Whitelist ─────────────────────────────────────────────────────────────
  document.querySelectorAll('input[name="wl-mode"]').forEach(function(r) {
    r.addEventListener('change', function() {
      document.getElementById('wl-list-area').style.display = r.value === 'list' ? 'block' : 'none';
    });
  });

  function renderWlChips() {
    var el = document.getElementById('wl-chips');
    el.innerHTML = _wlHandles.map(function(h, i) {
      return '<span class="vip-chip">@' + h + '<button class="chip-del" onclick="removeWlHandle(' + i + ')" title="Remove">✕</button></span>';
    }).join('');
  }

  function addWlHandle() {
    var inp = document.getElementById('wl-new-handle');
    var h = inp.value.trim().replace(/^@/, '');
    if (!h || _wlHandles.includes(h)) return;
    _wlHandles.push(h);
    inp.value = '';
    renderWlChips();
  }

  function removeWlHandle(idx) { _wlHandles.splice(idx, 1); renderWlChips(); }

  async function saveWhitelist() {
    var mode = document.querySelector('input[name="wl-mode"]:checked')?.value;
    var st = document.getElementById('wl-status');
    var isEn = document.body.classList.contains('en-mode');
    st.textContent = isEn ? '⏳ Saving...' : '⏳ 保存中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/update-whitelist'), {
        method: 'POST', headers: authHeaders(),
        body: JSON.stringify({ whitelist: mode === 'all' ? 'all' : _wlHandles })
      });
      var d = await r.json();
      st.textContent = d.ok ? (isEn ? '✅ Saved' : '✅ 已保存') : '❌ ' + d.error;
      st.style.color = d.ok ? '#86efac' : '#f87171';
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  // ── Dashboard secret ──────────────────────────────────────────────────────
  async function updateDashSecret() {
    var secret = document.getElementById('dash-secret-update').value.trim();
    var st = document.getElementById('secret-status');
    var isEn = document.body.classList.contains('en-mode');
    if (!secret) { st.textContent = isEn ? '⚠️ Cannot be empty' : '⚠️ 不能为空'; st.style.color = '#fbbf24'; return; }
    st.textContent = isEn ? '⏳ Saving...' : '⏳ 保存中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/update-secret'), {
        method: 'POST', headers: authHeaders(), body: JSON.stringify({ secret })
      });
      var d = await r.json();
      if (d.ok) { sessionStorage.setItem('dashSecret', secret); }
      st.textContent = d.ok ? (isEn ? '✅ Saved' : '✅ 已保存') : '❌ ' + d.error;
      st.style.color = d.ok ? '#86efac' : '#f87171';
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; }
  }

  // ── Re-auth ───────────────────────────────────────────────────────────────
  async function doReauth() {
    var btn = document.getElementById('reauthBtn');
    var st = document.getElementById('reauth-status');
    var isEn = document.body.classList.contains('en-mode');
    btn.disabled = true;
    st.textContent = isEn ? '⏳ Starting...' : '⏳ 启动中...'; st.style.color = '#94a3b8';
    try {
      var r = await fetch(getApiUrl('/api/agent/reauth-start'), {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ currentOrigin: window.location.origin })
      });
      var d = await r.json();
      if (!d.authUrl) { st.textContent = '❌ ' + (d.error || 'Failed'); st.style.color = '#f87171'; btn.disabled = false; return; }

      var authWin = window.open(d.authUrl, 'reauth', 'width=600,height=700');
      st.textContent = isEn ? '⏳ Waiting for authorization...' : '⏳ 等待授权…'; st.style.color = '#94a3b8';

      var pollTimer = setInterval(async function() {
        try {
          var pr = await fetch('/api/oauth/result?sessionId=' + d.sessionId);
          var pd = await pr.json();
          if (pd.status === 'done') {
            clearInterval(pollTimer); clearInterval(closedTimer);
            st.textContent = isEn ? '✅ Re-authorized!' : '✅ 重新授权成功！'; st.style.color = '#86efac';
            btn.disabled = false;
            if (authWin && !authWin.closed) authWin.close();
          } else if (pd.status === 'error') {
            clearInterval(pollTimer); clearInterval(closedTimer);
            st.textContent = '❌ ' + (pd.error || 'Error'); st.style.color = '#f87171'; btn.disabled = false;
          }
        } catch(e) { clearInterval(pollTimer); st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; btn.disabled = false; }
      }, 1500);

      var closedTimer = setInterval(function() {
        if (authWin && authWin.closed) {
          clearInterval(closedTimer); clearInterval(pollTimer);
          if (st.textContent.includes('⏳')) {
            st.textContent = isEn ? '⚠️ Window closed before completing.' : '⚠️ 授权窗口已关闭，请重试。';
            st.style.color = '#fbbf24'; btn.disabled = false;
          }
        }
      }, 1000);
    } catch(e) { st.textContent = '❌ ' + e.message; st.style.color = '#f87171'; btn.disabled = false; }
  }
</script>
</body>
</html>
