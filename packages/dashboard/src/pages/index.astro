---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Another X Agent Setup">
  <div id="stepNav" class="step-nav"></div>

  <!-- Step 0: Mode Selection -->
  <div class="step-panel active" id="s0">
    <h2>🌟 欢迎 / Welcome</h2>
    <div class="subtitle">请选择您要进行的操作 / Please select an operation</div>
    <div class="flex" style="flex-direction:column; gap:16px;">
      <button class="btn btn-primary" id="modeCreateBtn" style="padding: 24px; font-size: 1.1rem; height: auto;">🤖 创建并部署全功能 Agent<br><span style="font-size:0.8rem; opacity:0.8; font-weight:normal; margin-top:8px; display:inline-block;">完整定型、配置概率并激活后台巡逻进程<br>Deploy active agent to background daemon</span></button>
      <button class="btn btn-ghost" id="modeDistillBtn" style="padding: 24px; font-size: 1.1rem; border: 1px solid var(--primary); height: auto;">🔍 仅体验账号推文人格蒸馏<br><span style="font-size:0.8rem; opacity:0.8; font-weight:normal; margin-top:8px; display:inline-block;">免部署精简体验，提取任何人格化 Prompt<br>Distill persona system prompt only without deploying</span></button>
    </div>
  </div>

  <!-- Step 1: Authorization -->
  <div class="step-panel" id="s1">
    <h2>🔐 X 账号授权 <span style='font-size:0.7em;color:var(--text-muted)'>/ X Auth</span></h2>
    <div class="subtitle">授权 Agent 的 X 账号，获取 Refresh Token. / Authorize Agent's X account to get Refresh Token.</div>

    <div class="oauth-box">
      <h3>方式一：浏览器授权（推荐） / Browser Auth (Recommended)</h3>
      <p class="hint">确保 X App 的回调 URL 包含 (callback URL includes): <code id="cbHint" class="code-block"></code></p>
      <button class="btn btn-primary w-full mt-4" id="oauthBtn">🔗 打开授权页面 / Open Auth Page</button>
      <div class="oauth-status" id="oauthStatus" style="display:none">
        <div class="dot-pulse"></div><span>等待授权回调中…… / Waiting for callback...</span>
      </div>
      <div id="oauthDone" class="alert alert-success">✅ 授权成功！Refresh Token 已获取。 / Auth Successful! Refresh Token obtained.</div>
    </div>

    <div class="oauth-box mt-4">
      <h3>方式二：跳过 — 已有 Refresh Token / Skip — Already have Refresh Token</h3>
      <label>Refresh Token</label>
      <input type="password" id="manualRefresh" placeholder="粘贴已有的 refresh_token">
      <button class="btn btn-ghost mt-4 w-full" id="useManualBtn">✓ 使用此 Token / Use this Token</button>
      <div id="manualDone" class="alert alert-success">✅ 已使用手动输入的 Token。 / Manual Token applied.</div>
    </div>

    <div id="err1" class="alert alert-error"></div>
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="0">← 返回 / Back</button>
      <button class="btn btn-primary" id="s1next" disabled>下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 2: Gemini -->
  <div class="step-panel" id="s2">
    <h2>⚡ Gemini 配置 <span style='font-size:0.7em;color:var(--text-muted)'>/ Gemini Config</span></h2>
    <div class="subtitle">输入你的 Gemini API Key 和模型名称。 / Enter your Gemini API Key and Model Name.</div>
    
    <label>Gemini API Key</label>
    <input type="password" id="geminiKey" placeholder="AIza...">
    
    <label>模型名称 / Model Name</label>
    <div class="flex gap-2">
      <select id="geminiModelSelect" style="flex:1">
        <option value="" disabled selected>👉 请点右侧拉取列表 或 选择下方填入 / Click right to fetch or select below</option>
        <option value="_custom_">✍️ 手动输入... / Manual input...</option>
      </select>
      <input type="text" id="geminiModelCustom" style="display:none;flex:1" value="" placeholder="填入具体的模型名... / Enter specific model name...">
      <button class="btn btn-ghost" id="fetchModelsBtn" style="margin-top: 8px;">点此拉取列表 / Fetch List</button>
    </div>
    <p class="hint">填入 API Key 后点击按钮即可拉取该 Key 支持的所有可用模型。 / Enter API Key and click to fetch all available models.</p>
    
    <div id="err2" class="alert alert-error"></div>
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="1">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" data-step="3">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 3: Identity -->
  <div class="step-panel" id="s3">
    <h2>🎭 Agent 身份</h2>
    <div class="subtitle">Agent 的核心身份信息已与您的授权 X 账号强绑定。 / Agent core identity is securely bound.</div>
    
    <label>展示名称 / Display Name</label>
    <p class="hint">授权账号昵称 / Auth Account Name: <span id="hintMyName">（正在获取... / fetching...）</span></p>
    <input type="text" id="agentName" placeholder="自动从您的身份提供者中读取 / Auto read from identity provider" readonly disabled>
    
    <label>X @handle（不含 @ / without @）</label>
    <p class="hint">授权账号短柄 / Auth Account Handle: <span id="hintMyHandle">（正在获取... / fetching...）</span></p>
    <input type="text" id="agentHandle" placeholder="自动从您的身份提供者中读取 / Auto read from identity provider" readonly disabled>
    
    <label>源账号（逗号分隔，不含 @ / comma separated, no @ / without @）</label>
    <input type="text" id="sourceAccounts" placeholder="例 / Example: amber_medusozoa, elonmusk">
    <p class="hint">将抓取这些账号的推文用于人格蒸馏。 / Will fetch tweets from these accounts for persona distillation.</p>
    
    <div id="err3" class="alert alert-error"></div>
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="2">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" data-step="4">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 4: Distill -->
  <div class="step-panel" id="s4">
    <h2>🧪 人格蒸馏 <span style='font-size:0.7em;color:var(--text-muted)'>/ Distillation</span></h2>
    <div class="subtitle">拉取推文，利用 LLM 配置生成 system prompt。 / Fetch tweets and generate system prompt.</div>
    <div class="info-card" style="margin-bottom: 16px;">点击开始蒸馏后，后台将拉取最多一百条最近推文，并提取出此人的行文风格。 / Will extract writing style from recent tweets.</div>
    
    <label>配置生成语言 (Output Language)</label>
    <div class="flex gap-4" style="margin-top:8px;">
      <label style="margin-top:0; cursor:pointer;" class="flex items-center gap-2"><input type="radio" name="pLang" value="zh" checked> 🇨🇳 中文</label>
      <label style="margin-top:0; cursor:pointer;" class="flex items-center gap-2"><input type="radio" name="pLang" value="en"> 🇺🇸 English</label>
    </div>
    <p class="hint">💡 强烈建议生成 <b>中文</b> 提示词。同等人格配置下，高度凝练的中文能为您日常运行 Agent 省下极可观的 System Prompt Token 费率！ / Highly recommend generating Chinese prompt to save costs!</p>

    <button class="btn btn-primary w-full mt-4" id="startDistillBtn">🚀 开始一键蒸馏 / Start Distillation</button>
    
    <div id="distillLoading" style="display:none" class="mt-4">
      <div class="dot-pulse"></div><span>正在疯狂蒸馏中（约需 10-30 秒）…… / Distilling (takes 10-30s)...</span>
    </div>
    
    <div id="distillRes" class="alert alert-success mt-4"></div>
    
    <label>人格配置输出 / System Prompt Output</label>
    <textarea id="skillText" rows="12" placeholder="蒸馏出的 persona_skill 会显示在这里，您可自由微调补充。可以跳过蒸馏，自己手写！ / Distilled persona_skill will show here, you can handwrite or edit it!"></textarea>
    
    <div id="err4" class="alert alert-error"></div>
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="3">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" data-step="5">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 5: Tune (省略展示其余UI结构直接转到提交) -->
  <div class="step-panel" id="s5">
    <h2>🎯 样本调教 <span style='font-size:0.7em;color:var(--text-muted)'>/ Tuning</span></h2>
    <div class="subtitle">生成演练样本以调优 Agent 的发言。 / Generate practice samples to tune voice.</div>
    <button class="btn btn-ghost w-full" id="genSampleBtn">🎲 生成测试样本 / Generate Test Samples</button>
    <div id="sampleLoading" style="display:none" class="mt-4">
      <div class="dot-pulse"></div><span>正在思考…… / Thinking...</span>
    </div>
    <div id="sampleRes" class="sample-box"></div>
    <label>如果不满意，可修改上一页的系统提示词后重新生成。 / If unsatisfied, modify the system prompt and regenerate.</label>
    
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="4">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" id="s5next" data-step="6">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 6: Economy -->
  <div class="step-panel" id="s6">
    <h2>⚖️ 经济与参数 <span style='font-size:0.7em;color:var(--text-muted)'>/ Parameters</span></h2>
    <div class="subtitle">调整互动概率与冷却时间。 / Adjust interaction probability and cooldown.</div>
    
    <label>回复概率 / Reply Probability (0~1)</label>
    <input type="number" id="replyPct" step="0.1" value="0.2">
    
    <label>点赞概率 / Like Probability (0~1)</label>
    <input type="number" id="likePct" step="0.1" value="0.8">
    
    <label>回复冷却时间 / Reply Cooldown (Hours)</label>
    <input type="number" id="cooldown" value="3">
    
    <label class="flex items-center gap-2 mt-4">
      <input type="checkbox" id="enableEvo" checked>
      <span>开启夜间自动演进 / Enable Nightly Evolution</span>
    </label>
    <p class="hint">每晚 3:00 自动总结当天互动经验优化人格。 / Automatically summarize daily interactions to optimize persona.</p>
    
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="5">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" data-step="7">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 7: Memory -->
  <div class="step-panel" id="s7">
    <h2>🧠 记忆控制 <span style='font-size:0.7em;color:var(--text-muted)'>/ Memory</span></h2>
    <div class="subtitle">控制 Agent 会记忆并回应哪些人的互动。 / Control whose interactions the Agent remembers.</div>
    
    <label>白名单模式 / Whitelist Mode</label>
    <select id="memMode">
      <option value="specific">特定用户（仅白名单用户） / Specific Users (Whitelist only)</option>
      <option value="all">所有人（任何人互动均可触发记忆） / Everyone (Any interaction triggers memory)</option>
    </select>
    
    <div id="memUsersContainer" class="mt-4">
      <label>白名单用户 / VIP List</label>
      <input type="text" id="memUsers" placeholder="例：elonmusk, x">
    </div>
    
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="6">← 返回 / Back</button>
      <button class="btn btn-primary btn-next" data-step="8">下一步 → / Next</button>
    </div>
  </div>

  <!-- Step 8: Deploy -->
  <div class="step-panel" id="s8">
    <h2>🚀 部署配置 <span style='font-size:0.7em;color:var(--text-muted)'>/ Deploy</span></h2>
    <div class="subtitle">最后确认并保存您的 Agent 以激活生命流。 / Final confirmation to save your Agent and activate its life stream.</div>
    
    <div class="summary-box">
      <div id="summaryContent"></div>
    </div>
    <button class="btn btn-primary w-full mt-8" id="finishBtn" style="font-size: 1.2rem; padding: 16px;">✨ 点燃灵魂火种 / Ignite Soul (Deploy Agent)</button>
    <div id="deployRes" class="alert mt-4"></div>
    
    <div class="flex justify-between mt-8">
      <button class="btn btn-ghost btn-back" data-step="7">← 返回 / Back</button>
      <span></span>
    </div>
  </div>

<script>
// @ts-nocheck
// Logic identical to wizard.html but wrapped in modern JS scoped.
const api = async (endpoint, payload) => {
  const method = payload ? 'POST' : 'GET';
  const r = await fetch(endpoint, {
    method,
    headers: payload ? { 'Content-Type': 'application/json' } : undefined,
    body: payload ? JSON.stringify(payload) : undefined
  });
  return r.json();
};

const $ = id => document.getElementById(id);

const S = {
  step: 0,
  mode: 'create',
  geminiKey:'', geminiModel:'gemini-2.5-pro',
  accessToken:'', refreshToken:'',
  agentName:'', agentHandle:'', sourceAccounts:[],
  skill:'',
  vipList: [],
  memMode:'specific', memUsers:[],
  replyPct:0.2, likePct:0.8, cooldown:3,
  enableEvo:true,
};

const STEPS_CREATE = ['授权/Auth','Gemini','身份/Identity','蒸馏/Distill','调教/Tune','经济/Param','记忆/Memory','部署/Deploy'];
const STEPS_DISTILL = ['授权/Auth','Gemini','目标/Target','蒸馏/Distill','调教/Tune'];

function buildNav() {
  if (S.step === 0) { $('stepNav').innerHTML = ''; return; }
  const STEPS = S.mode === 'distill' ? STEPS_DISTILL : STEPS_CREATE;
  const nav = $('stepNav');
  nav.innerHTML = '';
  STEPS.forEach((lbl, i) => {
    const n = i + 1;
    const div = document.createElement('div');
    div.className = 'step-dot' + (n < S.step ? ' done' : n === S.step ? ' active' : '');
    div.innerHTML = `<div class="num">${n < S.step ? '✓' : n}</div><div class="lbl">${lbl}</div>`;
    nav.appendChild(div);
  });
}

function showErr(id, msg) {
  const el = $(id); if (!el) return;
  el.textContent = msg; el.className = 'alert alert-error show';
}
function clearErr(id) { const el = $(id); if(el) el.className = 'alert alert-error'; }

async function go(n) {
  clearErr('err' + S.step);
  if (n > S.step && !validate(S.step)) return;
  if (S.mode === 'distill' && n > 5) return; // Prevent forward nav in distill mode
  
  if (n === 3) {
    if (S.mode === 'distill') {
      $('identitySection').style.display = 'none';
      $('s3Title').innerHTML = '<h2>🎯 目标源账号 <span style="font-size:0.7em;color:var(--text-muted)">/ Target Auth</span></h2>';
      $('s3Subtitle').innerText = '在此输入需要拉取推文进行蒸馏分析的源账号。 / Enter the source accounts to pull and distill.';
    } else {
      $('identitySection').style.display = 'block';
      $('s3Title').innerHTML = '<h2>🎭 Agent 身份 <span style="font-size:0.7em;color:var(--text-muted)">/ Agent Identity</span></h2>';
      $('s3Subtitle').innerText = '核心身份信息已与您的授权 X 账号强绑定。 / Agent core identity is securely bound.';
    }
  }
  
  if (n === 5) {
    if (S.mode === 'distill') $('s5next').style.display = 'none';
    else $('s5next').style.display = 'inline-flex';
  }

  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  $('s' + n).classList.add('active');
  S.step = n;
  buildNav();
  if (n === 8) renderSummary();
}

function validate(step) {
  if (S.mode === 'distill' && step >= 5) return true; // safety
  if (step === 1 && !S.refreshToken) { showErr('err1','请先完成授权或填入 Refresh Token'); return false; }
  if (step === 2) {
    let mode = $('geminiModelSelect').style.display !== 'none' ? $('geminiModelSelect').value : $('geminiModelCustom').value;
    if (mode === '_custom_' && !$('geminiModelCustom').value.trim()) { showErr('err2','请输入模型名称'); return false; }
    if (mode !== '_custom_') $('geminiModelCustom').value = mode; 
    if (!$('geminiKey').value.trim()) { showErr('err2','请输入 Gemini API Key'); return false; }
    if (!$('geminiModelCustom').value.trim()) { showErr('err2','请输入模型名称'); return false; }
  }
  if (step === 3) {
    if (!$('sourceAccounts').value.trim()) { showErr('err3','请输入至少一个源账号'); return false; }
  }
  if (step === 4 && !$('skillText').value.trim()) { showErr('err4','请等待蒸馏完成或手动填入人格配置'); return false; }
  
  // collect
  if (step === 2) { 
    S.geminiKey = $('geminiKey').value.trim(); 
    S.geminiModel = $('geminiModelCustom').value.trim(); 
  }
  if (step === 3) {
    S.agentName = $('agentName').value.trim();
    S.agentHandle = $('agentHandle').value.trim();
    S.sourceAccounts = $('sourceAccounts').value.split(',').map(s=>s.trim()).filter(Boolean);
  }
  if (step === 4 || step === 5) {
    S.skill = $('skillText').value.trim();
  }
  if (step === 6) {
    S.replyPct = parseFloat($('replyPct').value);
    S.likePct = parseFloat($('likePct').value);
    S.cooldown = parseFloat($('cooldown').value);
    S.enableEvo = $('enableEvo').checked;
  }
  if (step === 7) {
    S.memMode = $('memMode').value;
    S.memUsers = $('memUsers').value.split(',').map(s=>s.trim().replace('@','')).filter(Boolean);
  }
  return true;
}

$('modeCreateBtn').addEventListener('click', () => { S.mode = 'create'; go(1); });
$('modeDistillBtn').addEventListener('click', () => { S.mode = 'distill'; go(1); });

// Attach generic navigation listeners
document.querySelectorAll('.btn-next').forEach(btn => {
  btn.addEventListener('click', (e) => {
    go(parseInt(e.target.dataset.step));
  });
});
document.querySelectorAll('.btn-back').forEach(btn => {
  btn.addEventListener('click', (e) => {
    go(parseInt(e.target.dataset.step));
  });
});

$('s1next').addEventListener('click', () => go(2));

// Init
$('cbHint').textContent = window.location.origin + '/callback';
buildNav();

// --- API Calls ---
let oauthPollTimer = null;
$('oauthBtn').addEventListener('click', async () => {
  $('oauthBtn').disabled = true;
  clearErr('err1');
  const r = await api('/api/oauth/start', {});
  if (r.error) { showErr('err1', r.error); $('oauthBtn').disabled = false; return; }
  
  const authWin = window.open(r.authUrl, '_blank');
  $('oauthStatus').style.display = 'flex';
  
  let checkClosedTimer = setInterval(() => {
    if (authWin && authWin.closed) {
      clearInterval(checkClosedTimer);
      clearInterval(oauthPollTimer);
      if ($('oauthDone').style.display !== 'block') { 
        showErr('err1', '⚠️ 授权窗口已被关闭。如果不小心关掉的，可以点击上面重试。');
        $('oauthBtn').disabled = false;
        $('oauthStatus').style.display = 'none';
      }
    }
  }, 1000);

  oauthPollTimer = setInterval(async () => {
    const res = await api('/api/oauth/result?sessionId=' + encodeURIComponent(r.sessionId));
    if (res.status === 'done') {
      clearInterval(oauthPollTimer);
      clearInterval(checkClosedTimer);
      S.accessToken = res.accessToken; S.refreshToken = res.refreshToken;
      $('oauthStatus').style.display = 'none';
      $('oauthDone').style.display = 'block';
      fetchIdentityHint();
      $('s1next').disabled = false;
    } else if (res.status === 'error') {
      clearInterval(oauthPollTimer);
      clearInterval(checkClosedTimer);
      showErr('err1', res.error ?? 'OAuth failed');
      $('oauthBtn').disabled = false; $('oauthStatus').style.display = 'none';
    }
  }, 1500);
});

$('useManualBtn').addEventListener('click', async () => {
  const rt = $('manualRefresh').value.trim();
  if (!rt) { showErr('err1','请填入 Refresh Token'); return; }
  const r = await api('/api/oauth/refresh', { refreshToken: rt });
  if (r.error) { showErr('err1','Token 验证失败：' + r.error); return; }
  S.refreshToken = rt; S.accessToken = r.accessToken;
  $('manualDone').style.display = 'block';
  fetchIdentityHint();
  $('s1next').disabled = false;
});

async function fetchIdentityHint() {
  const meRes = await api('/api/me', { accessToken: S.accessToken });
  if (!meRes.error && meRes.name && meRes.username) {
    if (!$('agentName').value) $('agentName').value = meRes.name;
    if (!$('agentHandle').value) $('agentHandle').value = meRes.username;
    $('hintMyName').textContent = meRes.name;
    $('hintMyHandle').textContent = meRes.username;
  }
}

// Models
$('geminiModelSelect').addEventListener('change', () => {
  if ($('geminiModelSelect').value === '_custom_') {
    $('geminiModelSelect').style.display = 'none';
    $('geminiModelCustom').style.display = 'block';
    $('geminiModelCustom').focus();
  }
});

$('fetchModelsBtn').addEventListener('click', async () => {
  const key = $('geminiKey').value.trim();
  if (!key) { showErr('err2', '请先输入 API Key'); return; }
  clearErr('err2');
  const btn = $('fetchModelsBtn');
  btn.disabled = true; btn.textContent = '拉取中...';
  try {
    const r = await api('/api/models?key=' + encodeURIComponent(key));
    btn.disabled = false; btn.textContent = '点此拉取列表';
    if (r.error) { showErr('err2', r.error); return; }
    if (r.models && r.models.length > 0) {
      let html = r.models.map(m => `<option value="${m}">${m}</option>`).join('');
      html += `<option disabled>───────────────</option><option value="_custom_">✍️ 手动输入其它...</option>`;
      $('geminiModelSelect').innerHTML = html;
      $('geminiModelSelect').style.display = 'block';
      $('geminiModelCustom').style.display = 'none';
      if (!$('geminiModelCustom').value || $('geminiModelCustom').value === 'gemini-2.5-pro') {
          $('geminiModelSelect').value = r.models[0];
      }
      showErr('err2', `✅ 成功拉取 ${r.models.length} 个模型 (已展开到列表)`);
      $('err2').className = 'alert alert-success show';
    } else { showErr('err2', '未找到可用的模型'); }
  } catch (err) {
    btn.disabled = false; btn.textContent = '点此拉取列表';
    showErr('err2', String(err));
  }
});

// Distill
$('startDistillBtn').addEventListener('click', async () => {
  $('distillLoading').style.display = 'flex';
  $('startDistillBtn').disabled = true;
  clearErr('err4');
  const payload = {
    sourceAccounts: $('sourceAccounts').value.split(',').map(s=>s.trim()).filter(Boolean),
    accessToken: S.accessToken,
    geminiApiKey: S.geminiKey,
    geminiModel: S.geminiModel,
    promptLang: document.querySelector('input[name="pLang"]:checked').value
  };
  const r = await api('/api/distill', payload);
  $('distillLoading').style.display = 'none';
  $('startDistillBtn').disabled = false;
  if(r.error) { showErr('err4', r.error); return; }
  
  let dHtml = '';
  if (r.fetched) {
    for (const [k,v] of Object.entries(r.fetched)) { dHtml += `@${k}: 抓取了 / fetched ${v} 条推文 / tweets<br>`; }
  }
  const el = $('distillRes');
  el.innerHTML = dHtml + '<br><b>✅ 蒸馏成功！ / Distillation Successful!</b>';
  el.className = 'alert alert-success show';
  $('skillText').value = r.skill;
});

// Tune
$('genSampleBtn').addEventListener('click', async () => {
  $('sampleLoading').style.display = 'flex'; $('genSampleBtn').disabled = true;
  const payload = { skill: $('skillText').value, geminiApiKey: S.geminiKey, geminiModel: S.geminiModel };
  const r = await api('/api/tune/sample', payload);
  $('sampleLoading').style.display = 'none'; $('genSampleBtn').disabled = false;
  
  if (r.error) { $('sampleRes').innerHTML = `<div style="color:var(--error)">❌ ${r.error}</div>`; return; }
  let h = '';
  r.samples.forEach(s => {
    h += `<div style="margin-top:16px;background:var(--input-bg);padding:12px;border-radius:12px;">`;
    if (s.type === 'spontaneous') { h += `<div style="font-size:12px;color:var(--primary)">✏️ 自发推文 / Spontaneous Tweet</div><div>${s.text}</div>`; }
    else { h += `<div style="font-size:12px;color:var(--primary)">💬 互动回复 / Interactive Reply</div><div style="font-size:13px;color:var(--text-muted)">Context: ${s.context}</div><div style="margin-top:8px">${s.text}</div>`; }
    h += `</div>`;
  });
  $('sampleRes').innerHTML = h;
});

// Memory UI Bind
$('memMode').addEventListener('change', () => {
  $('memUsersContainer').style.display = $('memMode').value === 'all' ? 'none' : 'block';
});

// Deploy
function renderSummary() {
  const html = `
    <li><strong>授权账号 / Auth Account:</strong> @${S.agentHandle}</li>
    <li><strong>模型配置 / Model Config:</strong> ${S.geminiModel}</li>
    <li><strong>源账号 / Source Accounts:</strong> ${S.sourceAccounts.join(', ')}</li>
    <li><strong>记忆模式 / Mode:</strong> ${S.memMode === 'all' ? '监听全网 / Listen to All' : '特定白名单 / Whitelist (' + S.memUsers.length + '人)'}</li>
    <li><strong>互动概率 / Interaction Pct:</strong> 点赞 / Like ${S.likePct*100}% | 回复 / Reply ${S.replyPct*100}%</li>
  `;
  $('summaryContent').innerHTML = `<ul style="color:var(--text-muted);font-size:1rem;line-height:2;">${html}</ul>`;
}

$('finishBtn').addEventListener('click', async () => {
  $('finishBtn').disabled = true;
  $('finishBtn').textContent = '部署配置中...';
  
  const payload = { ...S };
  const r = await api('/api/agent/create', payload);
  if (r.error) {
    const el = $('deployRes'); el.textContent = '部署失败: ' + r.error; el.className = 'alert alert-error show';
    $('finishBtn').disabled = false; $('finishBtn').textContent = '重试部署';
    return;
  }
  
  $('deployRes').innerHTML = `
    🎉 <b>Agent 部署成功！ / Agent Deployed Successfully!</b><br><br>
    您的 Agent 已储存于 SaaS 数据中心并开始自动巡逻。<br>Your Agent is active. Click below to enter your Dashboard:<br>
    <a href="/dashboard?id=${r.agentId}" style="display:inline-block;margin-top:16px" class="btn btn-primary">进入控制台 / Enter Dashboard</a>
  `;
  $('deployRes').className = 'alert alert-success show';
  $('finishBtn').style.display = 'none';
});
</script>

